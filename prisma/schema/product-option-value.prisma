model ProductOptionValue {
  id        Int @id @default(autoincrement())

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  optionId  Int
  option    Option @relation(fields: [optionId], references: [id])

  value     String

  @@index([productId])
  @@index([optionId])
  @@map("product_option_values")
}